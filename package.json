{
  "name": "price-dashboard-tooling",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/web/vite.config.js",
    "build": "npm run dashboard:build",
    "test": "npm run dashboard:test",
    "dashboard:dev": "vite --config apps/web/vite.config.js",
    "dashboard:build": "vite build --config apps/web/vite.config.js && node scripts/check-bundle-boundaries.mjs",
    "dashboard:guard": "node scripts/check-import-boundaries.mjs && node scripts/check-bundle-boundaries.mjs",
    "dashboard:preview": "vite preview --config apps/web/vite.config.js",
    "dashboard:test": "vitest run",
    "dashboard:test:visual": "npm run dashboard:build && playwright test --config playwright.visual.config.js",
    "dashboard:test:visual:update": "npm run dashboard:build && playwright test --config playwright.visual.config.js --update-snapshots",
    "apps:web:dev": "npm run dashboard:dev",
    "apps:web:service:serve": "node apps/web/service/runtimeServer.js",
    "apps:admin:check": "node apps/admin/src/index.js --check",
    "apps:admin:api:contracts:list": "node apps/admin/src/index.js api:contracts:list",
    "apps:admin:serve": "node apps/admin/src/server.js",
    "apps:worker:check": "node apps/worker/src/index.js --check",
    "apps:worker:migrations:describe": "node apps/worker/src/index.js migrations:describe",
    "apps:worker:migrations:bootstrap": "node apps/worker/src/index.js migrations:bootstrap",
    "apps:worker:migrations:artifact-ledger": "node apps/worker/src/index.js migrations:artifact-ledger",
    "apps:worker:migrations:apply": "node apps/worker/src/index.js migrations:apply",
    "apps:worker:migrations:bootstrap-and-apply": "node apps/worker/src/index.js migrations:bootstrap-and-apply",
    "platform:test:contracts": "vitest run --root . apps/admin/src/api/v1/handlers.contracts.test.js apps/worker/src/migrations/domainSchemaBootstrap.test.js apps/worker/src/migrations/postgresMigrationRunner.test.js packages/shared/contracts/api/httpRouteAdapter.test.js apps/worker/src/index.test.js",
    "packages:check": "node scripts/check-package-exports.mjs",
    "phase5:check": "npm run packages:check && npm run apps:admin:check && npm run apps:worker:check",
    "rigour:init": "node scripts/rigour-init.cjs"
  },
  "unused_allowlist": [
    "rigour-cli-shim",
    "jsdom"
  ],
  "rigour": {
    "unused_allowlist": [
      "rigour-cli-shim",
      "jsdom"
    ]
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^5.1.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "jsdom": "^29.1.1",
    "rigour-cli-shim": "file:tools/rigour-cli",
    "yaml": "^2.8.1",
    "vite": "^7.1.12",
    "vitest": "^4.1.6"
  }
}
