{
  "name": "price-dashboard-tooling",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config apps/web/vite.config.js",
    "build": "npm run dashboard:build",
    "test": "npm run dashboard:test",
    "dashboard:dev": "vite --config apps/web/vite.config.js",
    "dashboard:build": "vite build --config apps/web/vite.config.js && node scripts/check-bundle-boundaries.mjs",
    "dashboard:guard": "node scripts/check-import-boundaries.mjs && node scripts/check-bundle-boundaries.mjs",
    "dashboard:preview": "vite preview --config apps/web/vite.config.js",
    "dashboard:test": "vitest run",
    "dashboard:test:visual": "npm run dashboard:build && playwright test --config playwright.visual.config.js",
    "dashboard:test:visual:update": "npm run dashboard:build && playwright test --config playwright.visual.config.js --update-snapshots",
    "apps:web:dev": "npm run dashboard:dev",
    "apps:admin:check": "node apps/admin/src/index.js --check",
    "apps:worker:check": "node apps/worker/src/index.js --check",
    "packages:check": "node scripts/check-package-exports.mjs",
    "phase5:check": "npm run packages:check && npm run apps:admin:check && npm run apps:worker:check",
    "rigour:init": "node scripts/rigour-init.cjs"
  },
  "unused_allowlist": [
    "rigour-cli-shim"
  ],
  "rigour": {
    "unused_allowlist": [
      "rigour-cli-shim"
    ]
  },
  "dependencies": {
    "d3-geo": "^3.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^5.1.0",
    "jsdom": "^29.1.1",
    "rigour-cli-shim": "file:tools/rigour-cli",
    "vite": "^7.1.12",
    "vitest": "^4.1.6"
  }
}
