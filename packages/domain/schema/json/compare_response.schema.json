{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://esmip.dev/schemas/compare_response.schema.json",
  "title": "CompareResponse",
  "type": "object",
  "required": ["request_id", "data", "meta"],
  "properties": {
    "request_id": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["subjects", "lens", "horizon", "strengths", "tradeoffs", "confidence_matrix"],
      "properties": {
        "subjects": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["type", "id", "name"],
            "properties": {
              "type": { "enum": ["city", "region", "corridor", "cluster"] },
              "id": { "type": "string" },
              "name": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "lens": { "type": "string" },
        "horizon": { "enum": ["current", "h5", "h10", "long"] },
        "strengths": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["subject_id", "narrative", "drivers"],
            "properties": {
              "subject_id": { "type": "string" },
              "narrative": { "type": "string" },
              "drivers": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "tradeoffs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["subject_id", "narrative", "risk_factors"],
            "properties": {
              "subject_id": { "type": "string" },
              "narrative": { "type": "string" },
              "risk_factors": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "trajectory_divergence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metric_key", "subject_id", "delta"],
            "properties": {
              "metric_key": { "type": "string" },
              "subject_id": { "type": "string" },
              "delta": { "type": "number" }
            },
            "additionalProperties": false
          }
        },
        "confidence_matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["subject_id", "metric_key", "class", "score"],
            "properties": {
              "subject_id": { "type": "string" },
              "metric_key": { "type": "string" },
              "class": { "enum": ["source_backed", "composite", "inferential"] },
              "score": { "type": "number", "minimum": 0, "maximum": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "required": ["generated_at", "contract_version"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "contract_version": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
